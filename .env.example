# 五千年史馆后端环境变量示例
# 复制为 .env 并填入真实值，切勿提交 .env 到 git

# --- 数据库 ---
DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=change-me

# --- MySQL Docker 容器初始化 ---
MYSQL_ROOT_PASSWORD=change-me
MYSQL_USER=museum
MYSQL_PASSWORD=change-me

# --- LLM（智谱 GLM） ---
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_API_KEY=your-zhipu-key
LLM_MODEL=glm-4-flash

# --- Embedding ---
EMBEDDING_PROVIDER=zhipu
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_API_KEY=your-zhipu-key
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSIONS=1024

# --- RAG ---
# vector-store 可选 memory（开发）/ mysql（生产默认）/ redis
RAG_VECTOR_STORE=mysql
RAG_TOP_K=5
RAG_AUTO_INDEX=true

# --- Redis（生产用向量库） ---
REDIS_HOST=localhost
REDIS_PORT=6379
RAG_REDIS_INDEX=history_vectors

# --- ctext.org 典籍 API（可选，未配置 key 仅能用公开端点） ---
CTEXT_BASE_URL=https://api.ctext.org
CTEXT_API_KEY=
CTEXT_TIMEOUT_MS=8000
CTEXT_CACHE_TTL_MS=86400000

# --- Wikisource 典籍 API（无需 key） ---
WIKISOURCE_BASE_URL=https://zh.wikisource.org/w/api.php
WIKISOURCE_TIMEOUT_MS=8000
WIKISOURCE_CACHE_TTL_MS=86400000
WIKISOURCE_SEARCH_LIMIT=20

# --- 安全（生产环境必填） ---
# JWT 签名密钥，生产环境（spring.profiles.active=prod）必须配置，不少于 32 字符
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
# 前端域名，多个用逗号分隔；未配置则允许 *（仅开发环境）
FRONTEND_ORIGIN=http://localhost:5173
